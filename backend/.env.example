NODE_ENV=development
PORT=3000
# Use replica set for atomic multi-account transfers (see repo docker-compose.yml).
MONGO_URI=mongodb://127.0.0.1:27017/studentbank_banking?replicaSet=rs0
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:5173
# Optional: comma-separated admin emails (also used by seed:admin)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!
